# =============================================================================
# DEPLOY CONFIGURATION — Centralized Project Settings
# =============================================================================
# Copy this file to deploy/.env and fill in your values.
# When copying the deploy/ folder to another repo, edit ONLY this section
# and the domain names below.
# =============================================================================

# ── Project Identity ───────────────────────────────────────────
# Used for remote paths, SSH key names, and SSL cert directories.
# Defaults to the repo folder name if left empty.
# PROJECT_NAME=my-project

# ── Domains ────────────────────────────────────────────────────
# These are used by docker-compose Traefik labels, health checks,
# and GitHub Actions workflows.
DOMAIN_DEV=dev.tribalorigin.com
DOMAIN_STAGING=staging.tribalorigin.com
DOMAIN_PROD=tribalorigin.com

# ── Server Connection ──────────────────────────────────────────
HOST=your-server-ip
USER=root
SSH_KEY=~/.ssh/id_ed25519

# ── Environment ────────────────────────────────────────────────
# Options: dev, staging, prod (shared), prod-standalone
ENV=staging

# ── Docker Image ───────────────────────────────────────────────
APP_IMAGE=ghcr.io/your-org/your-repo:staging

# Optional: GitHub Container Registry login for private images
GHCR_USER=
GHCR_TOKEN=

# ── Health Check ───────────────────────────────────────────────
# If set, deploy.sh will poll this URL after deployment
HEALTH_URL=https://tribalorigin.com

# ── Let's Encrypt / Traefik ────────────────────────────────────
# Used by setup-server.sh when installing Traefik
ACME_EMAIL=admin@example.com

# ── Terraform ──────────────────────────────────────────────────
# These are automatically exported as TF_VAR_* when running
# make tf-init / tf-plan / tf-apply / infra
HCLOUD_TOKEN=your-hetzner-cloud-api-token
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_PROXIED=true
